# ============================================
# Agent Studio 环境变量配置
# ============================================
# 
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
#

# ============================================
# 数据库配置 (Supabase)
# ============================================

# Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名公钥 (可公开)
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Supabase 项目 ID
VITE_SUPABASE_PROJECT_ID=your_project_id

# ============================================
# AI 服务配置 (Edge Functions 使用)
# ============================================
# 
# 以下配置需要在 Supabase Dashboard -> Edge Functions -> Secrets 中设置
# 或在自托管环境中设置为环境变量
#

# AI Chat API 密钥 (必填)
# 支持 OpenAI、Azure OpenAI、Anthropic 等 OpenAI 兼容的 API
AI_API_KEY=sk-your-api-key

# AI Chat API 端点 (默认: OpenAI)
AI_GATEWAY_URL=https://api.openai.com/v1/chat/completions

# 默认 AI 模型 (可选)
AI_DEFAULT_MODEL=gpt-4o-mini

# ============================================
# Embedding 服务配置
# ============================================

# Embedding API 端点 (默认: OpenAI)
AI_EMBEDDING_URL=https://api.openai.com/v1/embeddings

# Embedding API 密钥 (如未设置则使用 AI_API_KEY)
AI_EMBEDDING_KEY=

# 默认 Embedding 模型
AI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# 可选服务配置
# ============================================

# Stripe 支付 (用于能力包购买)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Resend 邮件服务 (用于邀请码发送)
RESEND_API_KEY=re_your_resend_key
